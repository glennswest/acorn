# /etc/default/acornd — environment for the acornd systemd unit.
# Every flag on `acornd --help` is also readable as ACORND_<UPPERCASE_NAME>.

# --- Listeners -----------------------------------------------------------
ACORND_HTTP_ADDR=0.0.0.0:8443
ACORND_UDP_ADDR=0.0.0.0:5006

# --- State files (under StateDirectory=acorn) ----------------------------
ACORND_STORE=/var/lib/acorn/store.rvf
ACORND_WITNESS=/var/lib/acorn/witness.log
ACORND_CUSTODY=/var/lib/acorn/custody.key

# --- Store -------------------------------------------------------------
ACORND_METRIC=cosine

# --- Reflex tuning -----------------------------------------------------
# ACORND_PRESENCE_THRESHOLD=0.5
# ACORND_MOTION_THRESHOLD=0.7

# --- MQTT (set ACORND_MQTT_BROKER to enable; leave unset to disable) ----
# ACORND_MQTT_BROKER=mqtt://zman.g9.lo:1883
# ACORND_MQTT_TOPIC_PREFIX=acorn/events
# ACORND_MQTT_CLIENT_ID=acorn-zman
# ACORND_MQTT_USERNAME=
# ACORND_MQTT_PASSWORD=

# --- Logging -----------------------------------------------------------
RUST_LOG=info
